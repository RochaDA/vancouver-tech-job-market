# Data — raw/interim/processed files are regenerable, don't commit them
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Model artifacts (can be large)
models/*.pkl
models/*.joblib

# Python
__pycache__/
*.pyc
.venv/
venv/
.ipynb_checkpoints/

# Conda (in case a local --prefix env is created inside the repo)
env/
.conda/

# OS/editor
.DS_Store
.vscode/
